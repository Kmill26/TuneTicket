# PostgreSQL (local: Docker / Neon free tier / Supabase). Required for production (e.g. Vercel).
# Example Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# UploadThing (https://uploadthing.com) — song files for admin delivery
UPLOADTHING_TOKEN=""

# Resend (https://resend.com)
RESEND_API_KEY="re_..."
# Verified domain sender, e.g. TuneTicket <notifications@yourdomain.com> — Resend onboarding domain works for testing
RESEND_FROM="TuneTicket Orders <onboarding@resend.dev>"
# Where detailed order notifications go after ticket generation (default: kedm@mac.com)
ORDER_NOTIFICATION_EMAIL=""
# Bearer secret for GET/PATCH /api/admin/orders and POST /api/send-ticket-email
ADMIN_SECRET=""
